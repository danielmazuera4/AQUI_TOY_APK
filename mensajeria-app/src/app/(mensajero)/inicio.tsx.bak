import { useEffect, useRef, useState } from 'react';
import { useSafeAreaInsets } from 'react-native-safe-area-context';
import {
  ActivityIndicator,
  Alert,
  Animated,
  FlatList,
  Linking,
  Modal,
  PanResponder,
  ScrollView,
  RefreshControl,
  Pressable,
  StyleSheet,
  TextInput,
  Text,
  TouchableOpacity,
  View,
} from 'react-native';
import { router } from 'expo-router';
import * as ImagePicker from 'expo-image-picker';
import { useAuth } from '../../context/AuthContext';
import { getServiciosApi, aceptarServicioApi, completarPasoApi, reportarNovedadApi, abandonarServicioApi } from '../../services/api';
import { buildRouteUrl } from '../../utils/maps';
import { startBackgroundTracking } from '../../services/background-location';
import { MiniMap } from '../../components/mini-map';

export default function InicioMensajero() {
  const { usuario, logout } = useAuth();
  const insets = useSafeAreaInsets();
  const tabsOrden = ['progreso', 'sin_asignar', 'terminados'] as const;
  const [serviciosProgreso, setServiciosProgreso] = useState<any[]>([]);
  const [serviciosSinAsignar, setServiciosSinAsignar] = useState<any[]>([]);
  const [serviciosTerminados, setServiciosTerminados] = useState<any[]>([]);
  const [cargando, setCargando] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [tab, setTab] = useState<'progreso' | 'sin_asignar' | 'terminados'>('progreso');
  const [servicioExpandido, setServicioExpandido] = useState<number | null>(null);
  const [servicioDetalles, setServicioDetalles] = useState<any | null>(null);
  const [descripcionPaso, setDescripcionPaso] = useState<{ servicioId: number | null; paso: number | null; texto: string }>(
    {
      servicioId: null,
      paso: null,
      texto: '',
    }
  );
  const [descripcionModal, setDescripcionModal] = useState<{ servicioId: number | null; paso: number | null; texto: string }>(
    {
      servicioId: null,
      paso: null,
      texto: '',
    }
  );
  const [novedadAbierta, setNovedadAbierta] = useState<number | null>(null);
  const [tabsWidth, setTabsWidth] = useState(0);
  const [transicionDireccion, setTransicionDireccion] = useState<1 | -1>(1);
  const transitionAnim = useRef(new Animated.Value(1)).current;
  const indicatorAnim = useRef(new Animated.Value(0)).current;
  const panX = useRef(new Animated.Value(0)).current;
  const bottomBarHeight = 88; // altura reservada para barras fijas (px)
  const listPaddingBottom = Math.round(bottomBarHeight + insets.bottom + 16);

  const tabIndex = tabsOrden.indexOf(tab);
  const indicadorAncho = tabsWidth > 0 ? tabsWidth / 3 : 0;
  const indicadorFactor = 0.6; // ancho relativo del indicador dentro de la pestaña
  const indicadorWidth = indicadorAncho * indicadorFactor;
  const [selectedIds, setSelectedIds] = useState<number[]>([]);
  const [acceptingSelected, setAcceptingSelected] = useState(false);
  const [abandonarModalVisible, setAbandonarModalVisible] = useState(false);
  const [abandonarServicioId, setAbandonarServicioId] = useState<number | null>(null);
  const [abandonarMotivo, setAbandonarMotivo] = useState<string>('');
  const [abandonarEsOtro, setAbandonarEsOtro] = useState(false);
  const motivos = [
    'Imposibilidad de entrega',
    'Problema con el paquete',
    'Emergencia personal',
    'Otro',
  ];

  const toggleSelect = (id: number) => {
    setSelectedIds((prev) => {
      if (prev.includes(id)) return prev.filter((x) => x !== id);
      return [...prev, id];
    });
  };

  const handleAceptarSelected = async () => {
    if (selectedIds.length === 0) return;
    setAcceptingSelected(true);
    const successes: number[] = [];
    const failures: number[] = [];
    for (const id of selectedIds) {
      try {
        await aceptarServicioApi(id);
        void startBackgroundTracking(id);
        successes.push(id);
      } catch {
        failures.push(id);
      }
    }
    setAcceptingSelected(false);
    setSelectedIds([]);
    await cargarServicios();
    Alert.alert('Resultado', `Aceptados: ${successes.length}${failures.length ? `, fallidos: ${failures.length}` : ''}`);
  };
  const indicadorOffset = indicadorAncho > 0 ? (indicadorAncho - indicadorWidth) / 2 : 0;

  const cambiarTabPorDeslizamiento = (direccion: 'izquierda' | 'derecha') => {
    const indiceActual = tabsOrden.indexOf(tab);
    const siguienteIndice = direccion === 'izquierda' ? indiceActual + 1 : indiceActual - 1;

    if (siguienteIndice >= 0 && siguienteIndice < tabsOrden.length) {
      setTransicionDireccion(direccion === 'izquierda' ? 1 : -1);
      setTab(tabsOrden[siguienteIndice]);
    }
  };

  const cambiarTabConAnimacion = (siguienteTab: typeof tab, direccion: 1 | -1) => {
    if (siguienteTab === tab) return;
    setTransicionDireccion(direccion);
    setTab(siguienteTab);
  };

  const panResponder = PanResponder.create({
    onMoveShouldSetPanResponder: (_, gestureState) => {
      const esHorizontal = Math.abs(gestureState.dx) > 10;
      const dominaHorizontal = Math.abs(gestureState.dx) > Math.abs(gestureState.dy);
      return esHorizontal && dominaHorizontal;
    },
    onPanResponderGrant: () => {
      panX.setValue(0);
    },
    onPanResponderMove: (_, gestureState) => {
      // update panX for visual follow, clamp a bit
      panX.setValue(gestureState.dx);
      // update indicator to follow finger: fractional index
      if (indicadorAncho > 0) {
        const frac = -gestureState.dx / indicadorAncho;
        indicatorAnim.setValue(tabIndex + frac);
      }
    },
    onPanResponderRelease: (_, gestureState) => {
      const dx = gestureState.dx;
      // decide tab change threshold
      if (dx < -50) {
        cambiarTabPorDeslizamiento('izquierda');
      } else if (dx > 50) {
        cambiarTabPorDeslizamiento('derecha');
      }

      // animate panX back to 0
      Animated.spring(panX, { toValue: 0, useNativeDriver: true, speed: 20, bounciness: 6 }).start();

      // snap indicator to nearest tab index
      Animated.spring(indicatorAnim, { toValue: tabsOrden.indexOf(tab), useNativeDriver: true, speed: 20, bounciness: 8 }).start();
    },
  });

  useEffect(() => {
    transitionAnim.setValue(0);
    Animated.parallel([
      Animated.timing(transitionAnim, {
        toValue: 1,
        duration: 220,
        useNativeDriver: true,
      }),
      Animated.spring(indicatorAnim, {
        toValue: tabIndex >= 0 ? tabIndex : 0,
        useNativeDriver: true,
        speed: 18,
        bounciness: 10,
      }),
    ]).start();
  }, [indicatorAnim, tabIndex, transitionAnim]);

  useEffect(() => {
    cargarServicios();
  }, []);
  
  // Carga de servicios desde backend y filtrado por mensajero
  const cargarServicios = async () => {
    setCargando(true);
    try {
      const [progresoRes, sinAsignarRes, terminadosRes] = await Promise.all([
        getServiciosApi('en_progreso'),
        getServiciosApi('sin_asignar'),
        getServiciosApi('terminado'),
      ]);

      const progreso = progresoRes?.data || [];
      const sinAsignar = sinAsignarRes?.data || [];
      const terminados = terminadosRes?.data || [];

      // Filtrar por mensajero cuando exista
      setServiciosProgreso(progreso.filter((s: any) => s.mensajero?.id === usuario?.id));
      setServiciosSinAsignar(sinAsignar);
      setServiciosTerminados(terminados.filter((s: any) => s.mensajero?.id === usuario?.id));
    } catch (err: any) {
      console.error('Error cargarServicios', err?.response || err?.message || err);
      Alert.alert('Error', 'No se pudieron cargar los servicios. Revisa la conexión o el backend.');
    } finally {
      setCargando(false);
      setRefreshing(false);
    }
  };

  return (
    <View style={styles.container}>
      <View style={styles.header}>
        <View>
          <Text style={styles.headerTitle}>Hola, {usuario?.username || 'Mensajero'}</Text>
          <Text style={styles.headerSubtitle}>{usuario?.empresa?.nombre || ''}</Text>
        </View>
        <TouchableOpacity onPress={logout} style={styles.logoutButton}>
          <Text style={styles.logoutText}>Salir</Text>
        </TouchableOpacity>
      </View>

      <View style={{ padding: 12 }}>
        <TouchableOpacity onPress={() => { setRefreshing(true); cargarServicios(); }} style={{ backgroundColor: '#1d4ed8', padding: 10, borderRadius: 8 }}>
          <Text style={{ color: '#fff', fontWeight: '700' }}>Actualizar servicios</Text>
        </TouchableOpacity>
      </View>

      {cargando ? (
        <ActivityIndicator size="large" color="#1d4ed8" style={{ marginTop: 24 }} />
      ) : (
        <View style={{ flex: 1, paddingHorizontal: 12 }}>
          <Text style={{ fontWeight: '800', marginBottom: 8 }}>En progreso ({serviciosProgreso.length})</Text>
          <FlatList
            data={serviciosProgreso}
            keyExtractor={(item: any) => String(item.id)}
            renderItem={({ item }: any) => (
              <View style={{ padding: 12, backgroundColor: '#fff', borderRadius: 10, marginBottom: 8 }}>
                <Text style={{ fontWeight: '800' }}>{item.orden ? `Orden #${item.orden}` : `ID ${item.id}`}</Text>
                <Text>{item.cliente?.empresa?.nombre || item.cliente?.username || item.creado_por?.username || '-'}</Text>
                <Text style={{ color: '#6b7280' }}>{item.origen} → {item.destino}</Text>
              </View>
            )}
            ListEmptyComponent={<Text style={{ color: '#6b7280', marginTop: 16 }}>No hay servicios en progreso.</Text>}
          />
        </View>
      )}
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#f4f5f7' },
  header: { backgroundColor: '#f4f5f7', paddingHorizontal: 18, paddingTop: 52, paddingBottom: 10, flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center' },
  headerTitle: { color: '#111827', fontSize: 18, fontWeight: '800' },
  headerSubtitle: { color: '#6b7280', fontSize: 13 },
